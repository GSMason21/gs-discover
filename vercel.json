{
  "buildCommand": "npm install && npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/submit.js": {
      "includeFiles": "api/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
