{
  "buildCommand": "npm install && npx vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/innovation-explorer/(.*)", "destination": "/quizzes/innovation-explorer/$1" },
    { "source": "/leadership/(.*)",          "destination": "/quizzes/leadership/$1" },
    { "source": "/innovation-explorer",      "destination": "/quizzes/innovation-explorer/index.html" },
    { "source": "/leadership",               "destination": "/quizzes/leadership/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "https://www.gettingsmart.com", "permanent": true }
  ]
}
